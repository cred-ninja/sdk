{
  "name": "@cred-ninja/sdk",
  "version": "1.0.0",
  "description": "OAuth2 credential delegation for AI agents",
  "private": true,
  "workspaces": [
    "packages/oauth",
    "packages/tofu",
    "packages/vault",
    "packages/sdk",
    "packages/sdk-python",
    "packages/integrations/langchain",
    "packages/integrations/crewai",
    "packages/integrations/openai-agents",
    "packages/integrations/autogen",
    "packages/integrations/semantic-kernel",
    "packages/integrations/vercel-ai",
    "packages/mcp",
    "packages/server",
    "packages/create-cred-app",
    "packages/guard"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "overrides": {
    "esbuild": "0.27.4",
    "express-rate-limit": "8.3.1",
    "hono": "4.12.8"
  },
  "engines": {
    "node": ">=18"
  }
}
