{
  "name": "@credninja/mcp",
  "version": "1.0.0",
  "description": "MCP server for OAuth2 credential delegation. Secure token brokering for AI agents",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "cred-mcp": "./dist/cli.js"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{ recursive: true, force: true })\" && npx tsc",
    "dev": "tsx src/cli.ts"
  },
  "files": [
    "dist",
    "LICENSE",
    "NOTICE"
  ],
  "keywords": [
    "cred",
    "mcp",
    "oauth",
    "delegation",
    "ai-agents",
    "credentials"
  ],
  "author": "Cred",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@credninja/sdk": "*"
  },
  "peerDependencies": {
    "@credninja/oauth": "^1.0.0",
    "@credninja/vault": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@credninja/oauth": {
      "optional": true
    },
    "@credninja/vault": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.10.6",
    "tsx": "^4.7.0"
  }
}
