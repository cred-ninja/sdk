{
  "name": "@credninja/sdk",
  "version": "1.0.0",
  "description": "OAuth2 credential delegation SDK for AI agents. Works standalone or with Cred Cloud",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/cjs/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cred",
    "oauth",
    "delegation",
    "ai-agents",
    "credentials"
  ],
  "author": "Cred",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@credninja/oauth": "^0.1.0",
    "@credninja/vault": "^0.1.0"
  },
  "peerDependenciesMeta": {
    "@credninja/oauth": {
      "optional": true
    },
    "@credninja/vault": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  }
}
