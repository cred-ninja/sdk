{
  "name": "@credninja/sdk",
  "version": "1.0.0",
  "description": "OAuth2 credential delegation SDK for AI agents. Works standalone or with a self-hosted Cred server",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/cjs/index.d.ts"
    }
  },
  "files": [
    "dist/cjs",
    "dist/esm",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "npx tsc -p tsconfig.cjs.json && npx tsc -p tsconfig.esm.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cred",
    "oauth",
    "delegation",
    "ai-agents",
    "credentials"
  ],
  "author": "Cred",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@credninja/oauth": "^1.0.0",
    "@credninja/vault": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@credninja/oauth": {
      "optional": true
    },
    "@credninja/vault": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  }
}
