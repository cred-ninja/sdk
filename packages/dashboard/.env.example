# Cred Dashboard — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env — it's in .gitignore.
#
# See README.md for setup instructions for each provider.

# ── Server ────────────────────────────────────────────────────────────────────
# Public URL of this dashboard. Used as the OAuth redirect URI.
# Default: http://localhost:3456 (fine for local dev and SSH tunnel access)
# Set this when deploying to a server with a real domain or IP.
REDIRECT_URI=http://localhost:3456/callback

# ── Agent API ─────────────────────────────────────────────────────────────────
# Shared secret for agents calling GET /api/token/:provider.
# Generate with: openssl rand -hex 32
# If not set, the token API returns 403 (disabled).
AGENT_TOKEN=

# ── Vault ─────────────────────────────────────────────────────────────────────
# Passphrase used to encrypt the local credential vault (AES-256-GCM).
# Use a strong random string. Keep it secret.
VAULT_PASSPHRASE=

# ── Google (Drive, Gmail, Calendar) ───────────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
# Create an OAuth 2.0 Client ID (Web application)
# Redirect URI: http://localhost:3456/callback  (or your server URL)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── GitHub ─────────────────────────────────────────────────────────────────────
# https://github.com/settings/developers → New OAuth App
# Callback URL: http://localhost:3456/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Slack ──────────────────────────────────────────────────────────────────────
# https://api.slack.com/apps → Create New App → OAuth & Permissions
# Redirect URL: http://localhost:3456/callback
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# ── Notion ─────────────────────────────────────────────────────────────────────
# https://www.notion.so/my-integrations → New integration (public, OAuth)
# Redirect URI: http://localhost:3456/callback
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# ── Salesforce ─────────────────────────────────────────────────────────────────
# Setup → App Manager → New Connected App → Enable OAuth
# Callback URL: http://localhost:3456/callback
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
