{
  "name": "@credninja/server",
  "version": "1.0.0",
  "description": "Self-hosted credential delegation server for AI agents. Uses @credninja/oauth + @credninja/vault",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "cred-server": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run"
  },
  "files": [
    "dist",
    ".env.example"
  ],
  "keywords": [
    "cred",
    "oauth",
    "delegation",
    "ai-agents",
    "credentials",
    "server",
    "self-hosted"
  ],
  "author": "Cred",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@credninja/oauth": "^1.0.0",
    "@credninja/tofu": "^1.0.0",
    "@credninja/vault": "^1.0.0",
    "express": "^4.21.0"
  },
  "optionalDependencies": {
    "@credninja/guard": "^0.1.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "vitest": "^4.0.18",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2"
  }
}
