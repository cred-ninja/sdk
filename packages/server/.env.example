# ─── Cred Server Configuration ───────────────────────────────────────────────
# Copy this file to .env and fill in the values.

# Server
PORT=3456
HOST=127.0.0.1

# Vault encryption passphrase (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
VAULT_PASSPHRASE=change-me-to-a-strong-random-string

# Vault storage: 'file' (default) or 'sqlite'
VAULT_STORAGE=file

# Vault file path (relative to server working directory)
VAULT_PATH=./data/vault.json

# TOFU identity storage: defaults to VAULT_STORAGE and a separate file path
TOFU_STORAGE=file
TOFU_PATH=./data/tofu.json

# Agent token for API access (generate: node -e "console.log('cred_at_' + require('crypto').randomBytes(32).toString('hex'))")
# This token is used by agents to authenticate when requesting delegated credentials.
# Store it securely — it grants access to all connected provider tokens.
AGENT_TOKEN=

# ─── OAuth Providers ─────────────────────────────────────────────────────────
# Add credentials for each provider you want to support.
# Get these from each provider's developer console.

# Google (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DEFAULT_SCOPES=openid,email,profile

# GitHub (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Slack (https://api.slack.com/apps)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Notion (https://www.notion.so/my-integrations)
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# Salesforce (https://login.salesforce.com/lightning/setup/NavigationMenus/home)
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=

# Linear (https://linear.app/settings/api)
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=

# HubSpot (https://developers.hubspot.com/)
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

# ─── Redirect URI ────────────────────────────────────────────────────────────
# Must match what's registered in each provider's developer console.
# For local dev: http://localhost:3456/connect/{provider}/callback
# For production: https://your-domain.com/connect/{provider}/callback
REDIRECT_BASE_URI=http://localhost:3456

# ─── Web Bot Auth Ingress Verification ───────────────────────────────────────
# WEB_BOT_AUTH_MODE: off (default), optional, or require
WEB_BOT_AUTH_MODE=off

# Replay-defense nonce storage for incoming Web Bot Auth requests.
# Use sqlite and a shared path if you run multiple Cred instances.
WEB_BOT_AUTH_NONCE_STORE=memory
# WEB_BOT_AUTH_NONCE_PATH=./data/web-bot-auth-nonces.sqlite
